# Copy this file to .env and fill in your values
# cp .env.example .env

DB_USER=your_db_user
DB_PASSWORD=your_strong_password_here
DB_NAME=pubsave
LOG_LEVEL=INFO
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# Optional: enables semantic search and RAG /ask endpoint
# Without this key, CRUD and keyword search work normally. RAG endpoints return 503.
OPENAI_API_KEY=
